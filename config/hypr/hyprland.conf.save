source = ~/.config/hypr/extra/hyprland-colors.conf
################
### MONITORS ###
################
source = monitors.conf
source = workspaces.conf

###################
### MY PROGRAMS ###
###################
$terminal = kitty
$fileManager = kitty yazi
$browser = firefox
$email = betterbird
$editor = code
$musicPlayer = spotify
$notificationDaemon = swaync-client -t
$wallpaper = waypaper
# $colorpicker = hyprpicker -a -l
$screenshot = hyprshot -m region --freeze -o ~/pictures/screenshots/ -f $(date '+%d.%m.%Y-%H:%M:%S').png
$menu = $HOME/.config/rofi/launcher/launcher.sh
$clipboard = $HOME/.config/rofi/clipboard/clipboard.sh

#################
### AUTOSTART ###
#################
exec-once = awww-daemon
exec-once = gsr-ui
exec-once = chown $USER:$USER -R $HOME
exec-once = udiskie &
exec-once = systemctl --user start hyprpolkitagent
exec-once = wl-paste --watch cliphist store
exec-once = wl-paste --type text --watch cliphist -max-items=50 store
exec-once = wl-paste --type image --watch cliphist -max-items=50 store
exec-once = hyprctl setcursor Bibata-Modern-Ice 24
exec-once = gsettings set org.gnome.desktop.interface cursor-theme Bibata-Modern-Ice
exec-once = $HOME/.config/hypr/scripts/low-power.sh
exec-once = $HOME/.config/waybar/launch.sh

#############################
### ENVIRONMENT VARIABLES ###
#############################
env = XCURSOR_SIZE,24
env = HYPRCURSOR_SIZE,24
env = HYPRCURSOR_THEME,Bibata-Modern-Ice

#####################
### LOOK AND FEEL ###
#####################
general {
    gaps_in = 3
    gaps_out = 5
    gaps_workspaces = 0

    border_size = 1
    col.active_border = rgba(6b8cadcc)
    col.inactive_border = rgba(6b8cad22)
    resize_on_border = false

    no_focus_fallback = true
    allow_tearing = true

    snap {
        enabled = true
        window_gap = 4
        monitor_gap = 5
        respect_gaps = true
    }
}

dwindle {
    preserve_split = true
    smart_split = false
    smart_resizing = false
}

decoration {
    rounding_power = 2.4
    rounding = 6

    blur {
        enabled = true
        size = 3
        passes = 5
        new_optimizations = true
        xray = false
        vibrancy = 0
        vibrancy_darkness = 0.30
    }

    shadow {
        enabled = true
        range = 50
        offset = 0 4
        render_power = 10
        color = rgba(00000027)
    }

    dim_inactive = true
    dim_strength = 0.05
    dim_special = 0.07
}

animations {
    enabled = true
    bezier = expressiveFastSpatial, 0.42, 1.67, 0.21, 0.90
    bezier = expressiveSlowSpatial, 0.39, 1.29, 0.35, 0.98
    bezier = expressiveDefaultSpatial, 0.38, 1.21, 0.22, 1.00
    bezier = emphasizedDecel, 0.05, 0.7, 0.1, 1
    bezier = emphasizedAccel, 0.3, 0, 0.8, 0.15
    bezier = standardDecel, 0, 0, 0, 1
    bezier = menu_decel, 0.1, 1, 0, 1
    bezier = menu_accel, 0.52, 0.03, 0.72, 0.08
    bezier = stall, 1, -0.1, 0.7, 0.85

    animation = windowsIn, 1, 3, emphasizedDecel, popin 80%
    animation = fadeIn, 1, 3, emphasizedDecel
    animation = windowsOut, 1, 2, emphasizedDecel, popin 90%
    animation = fadeOut, 1, 2, emphasizedDecel
    animation = windowsMove, 1, 3, emphasizedDecel, slide
    animation = border, 1, 10, emphasizedDecel
    animation = layersIn, 1, 2.7, emphasizedDecel, popin 93%
    animation = layersOut, 1, 2.4, menu_accel, popin 95%
    animation = fadeLayersIn, 1, 0.5, menu_decel
    animation = fadeLayersOut, 1, 2.7, stall
    animation = workspaces, 1, 7, menu_decel, slide
    animation = specialWorkspaceIn, 1, 2.8, emphasizedDecel, slidevert
    animation = specialWorkspaceOut, 1, 1.2, emphasizedAccel, slidevert
    animation = zoomFactor, 1, 3, emphasizedDecel
}

master {
    new_status = master
}

misc {
    disable_hyprland_logo = true
    disable_splash_rendering = true
    vrr = 1
    mouse_move_enables_dpms = true
    key_press_enables_dpms = true
    animate_manual_resizes = false
    animate_mouse_windowdragging = false
    enable_swallow = false
    swallow_regex = (foot|kitty|allacritty|Alacritty)
    on_focus_under_fullscreen = 2
    allow_session_lock_restore = true
    session_lock_xray = true
    initial_workspace_tracking = false
    focus_on_activate = true
}

#############
### INPUT ###
#############
input {
    kb_layout = us
    kb_variant = intl
    kb_model =
    kb_options =
    kb_rules =

    follow_mouse = 1
    force_no_accel = true
    sensitivity = 0

    touchpad {
        natural_scroll = false
    }
}

cursor {
    sync_gsettings_theme = true
    no_hardware_cursors = 2
}

gesture = 3, swipe, move,
gesture = 4, horizontal, workspace
gesture = 3, pinch, float

gestures {
    workspace_swipe_distance = 700
    workspace_swipe_cancel_ratio = 0.2
    workspace_swipe_min_speed_to_force = 5
    workspace_swipe_direction_lock = true
    workspace_swipe_direction_lock_threshold = 10
    workspace_swipe_create_new = true
    workspace_swipe_invert = true
}

device {
    name = epic-mouse-v1
    sensitivity = -0.5
}

###################
### KEYBINDINGS ###
###################
$mainMod = SUPER

bind = $mainMod, Q, exec, $terminal
bind = $mainMod, C, killactive,
bind = $mainMod, M, fullscreen, 1
bind = $mainMod, E, exec, $fileManager
bind = $mainMod, N, exec, $editor
bind = $mainMod, W, exec, $browser
bind = $mainMod, T, exec, $wallpaper
bind = $mainMod, B, exec, $musicPlayer
bind = $mainMod, O, exec, $notificationDaemon
bind = $mainMod, 0, exec, better-control
bind = SUPER_SHIFT, S, exec, $screenshot
bind = $mainMod, F, fullscreen,
bind = $mainMod, S, togglefloating
bind = $mainMod, Tab, cyclenext, bringactivetotop
bind = ALT, Tab, workspace, previous
bind = SUPER, L, exec, hyprlock
bind = $mainMod, SPACE, exec, $menu
bind = $mainMod, V, exec, $clipboard
bind = $mainMod, ., exec, $emoji
bind = $mainMod, P, exec, nwg-displays
bind = CONTROL SHIFT, Escape, exec, missioncenter

bind = $mainMod, left, movefocus, l
bind = $mainMod, right, movefocus, r
bind = $mainMod, up, movefocus, u
bind = $mainMod, down, movefocus, d

bind = $mainMod, 1, workspace, 1
bind = $mainMod, 2, workspace, 2
bind = $mainMod, 3, workspace, 3
bind = $mainMod, 4, workspace, 4
bind = $mainMod, 5, workspace, 5
bind = $mainMod, 6, workspace, 6
bind = $mainMod, 7, workspace, 7
bind = $mainMod, 8, workspace, 8
bind = $mainMod, 9, workspace, 9

bind = $mainMod SHIFT, 1, movetoworkspace, 1
bind = $mainMod SHIFT, 2, movetoworkspace, 2
bind = $mainMod SHIFT, 3, movetoworkspace, 3
bind = $mainMod SHIFT, 4, movetoworkspace, 4
bind = $mainMod SHIFT, 5, movetoworkspace, 5
bind = $mainMod SHIFT, 6, movetoworkspace, 6
bind = $mainMod SHIFT, 7, movetoworkspace, 7
bind = $mainMod SHIFT, 8, movetoworkspace, 8
bind = $mainMod SHIFT, 9, movetoworkspace, 9

bind = $mainMod, mouse_down, workspace, e+1
bind = $mainMod, mouse_up, workspace, e-1

bindm = $mainMod, mouse:272, movewindow
bindm = $mainMod, mouse:273, resizewindow

bindel = ,XF86AudioRaiseVolume, exec, wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+ && ~/.local/bin/volume.sh
bindel = ,XF86AudioLowerVolume, exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- && ~/.local/bin/volume.sh
bindel = ,XF86AudioMute, exec, wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle && ~/.local/bin/volume.sh
bindel = ,XF86AudioMicMute, exec, wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle && ~/.local/bin/mic.sh
bindel = ,XF86MonBrightnessUp, exec, brightnessctl -e4 -n2 set 5%+ && ~/.local/bin/brightness.sh
bindel = ,XF86MonBrightnessDown, exec, brightnessctl -e4 -n2 set 5%- && ~/.local/bin/brightness.sh

bindr = , capslock, exec, ~/.local/bin/capslock.sh
bindr = , num_lock, exec, ~/.local/bin/numlock.sh

bindl = , XF86AudioNext, exec, playerctl next
bindl = , XF86AudioPause, exec, playerctl play-pause
bindl = , XF86AudioPlay, exec, playerctl play-pause
bindl = , XF86AudioPrev, exec, playerctl previous

##############################
### WINDOWS AND WORKSPACES ###
##############################
windowrule = suppress_event maximize, match:class .*
windowrule = no_focus on, match:class ^$, match:title ^$, match:xwayland 1, match:float 1, match:fullscreen 0, match:pin 0
windowrule = opacity 0.0 override, no_anim on, no_initial_focus on, max_size 1 1, no_blur on, no_focus on, match:class ^(xwaylandvideobridge)$

layerrule = blur on, ignore_alpha 0, match:namespace waybar
layerrule = blur on, ignore_alpha 0, match:namespace swaync-control-center
layerrule = blur on, ignore_alpha 0, match:namespace swaync-notification-window
layerrule = blur on, ignore_alpha 0, match:namespace rofi

source = ~/.config/hypr/extra/current_mode.conf

windowrule = no_anim on, no_blur on, opaque on, match:fullscreen 1
windowrule = no_anim on, no_blur on, no_shadow on, float on, match:class ^(ueberzugpp)$
windowrule = immediate on, workspace 6, match:class ^(osu!.exe)$
windowrule = immediate on, workspace 6, match:class ^(net.neomodnet.neomod)$

windowrule = workspace 1, match:class ^(firefox|librewolf|waterfox|zen|brave-browser|helium|chromium)$
windowrule = workspace 2, match:class ^(discord|vesktop|org.telegram.desktop|com.ayugram.desktop)$
windowrule = workspace 3, match:class ^(spotify|mpv)$
windowrule = workspace 4, match:class ^(Code|code)$
windowrule = workspace 4, match:class ^(obsidian)$
windowrule = workspace 5, match:class ^(steam|heroic)$
windowrule = workspace 6, fullscreen on, match:title ^(.*Minecraft.*)$
windowrule = workspace 6, match:class ^(steam_app_\d+)$
windowrule = workspace 6, match:class ^(cs2)$
windowrule = workspace 6, match:class ^(dota2)$

windowrule = opacity 0.52 override, match:class ^(code)$

windowrule = float on, match:class ^(org.pulseaudio.pavucontrol)$
windowrule = float on, match:class ^(better_control.py)$
windowrule = float on, match:class ^(waypaper)$
windowrule = float on, match:class ^(org.twosheds.iwgtk)$
windowrule = float on, pin on, match:class ^(ripdrag)$
windowrule = opacity 0.80 override, match:class ^(thunar)$

windowrule {
    name = fightcade-emulator
    match:class = ^(fcadefbneo\.exe)$
    float = on
    center = on
}

windowrule {
    name = float-console-prismlauncher
    match:class = ^(org.prismlauncher.PrismLauncher)$
    match:title = ^(.*Console window.*)$
    float = on
    opaque = on
    size = 1100 600
    center = on
}

windowrule {
    name = float-mpv
    match:class = ^(mpv)$
    float = on
    opaque = on
    size = 640 360
    center = on
}

windowrule {
    name = float-nwg-displays
    match:class = ^(nwg-displays)$
    float = on
    opaque = on
    size = 1102 662
    center = on
}

windowrule {
    name = float_qbittorrent_all
    match:class = ^(org.qbittorrent.qBittorrent)$
    float = on
    center = on
    size = 650 450
}

windowrule {
    name = tile_qbittorrent_main
    match:class = ^(org.qbittorrent.qBittorrent)$
    match:title = ^(qBittorrent v).*$
    float = off
}

windowrule {
    name = steam-general
    match:class = ^(steam)$
    float = off
    opaque = on
}

windowrule {
    name = steam-main-window
    match:class = ^(steam)$
    match:title = ^(Steam)$
    size = 1100 600
    center = on
}

windowrule {
    name = steam-friends
    match:class = ^(steam)$
    match:title = ^(Friends List)$
    float = on
    size = 460 580
    center = on
}

windowrule {
    name = steam-settings
    match:class = ^(steam)$
    match:title = ^(Steam Settings)$
    float = on
    size = 1100 600
    center = on
}

windowrule {
    name = steam-special-offers
    match:class = ^(steam)$
    match:title = ^(Special Offers)$
    float = on
    center = on
}

windowrule {
    name = steam-idle
    match:class = ^(steam)$
    idle_inhibit = fullscreen
}

windowrule {
    name = gparted
    match:class = ^(GParted)$
    float = on
    size = 652 431
    center = on
}

windowrule {
    name = float-blueman
    match:class = ^(blueman-manager)$
    float = on
    size = 530 313
    center = on
}

windowrule {
    name = peaclock
    match:class = ^(peaclock)$
    float = on
    center = on
    size = 406 179
}

windowrule {
    name = cava
    match:class = ^(cava)$
    float = on
    size = 791 488
    center = on
}

windowrule {
    name = btop
    match:title = ^(btop)$
    float = on
    size = 1080 607
    center = on
}

windowrule {
    name = missioncenter
    match:class = ^(io.missioncenter.MissionCenter)$
    float = on
    size = 1128 715
    center = on
}

windowrule {
    name = pip-global
    match:title = ^([Pp]icture[-\s]?[Ii]n[-\s]?[Pp]icture)(.*)$
    float = on
    pin = on
    size = 645 363
    move = (monitor_w-window_w-20) (monitor_h-window_h-20)
    no_dim = on
    opaque = on
}

windowrule {
    name = galculator
    match:class = ^(galculator)$
    float = on
    size = 410 457
    center = on
}

windowrule {
    name = style-pinned-windows
    match:pin = on
    no_dim = on
    border_color = rgb(328E6E)
    border_size = 2
}

windowrule {
    name = float-dialogs-title
    match:title = ^(Open|Open File|Select a File|Choose wallpaper|Open Folder|Save As|Rename|Library|File Upload|Authentication Required|Add Folder to Workspace|Choose Files|Confirm to replace files|File Operation Progress)(.*)$|^(.*dialog.*)$
    float = on
    center = on
}

windowrule {
    name = float-dialogs-class
    match:class = ^(org.gnome.FileRoller|[Xx]dg-desktop-portal-gtk|.*dialog.*)$
    float = on
    center = on
    size = 816 537
}

windowrule {
    name = float-bitwarden-browser
    match:class = ^(librewolf)$
    match:title = ^(.*Bitwarden.*)$
    float = on
    size = 1100 600
    center = on
}
bind = SUPER SHIFT, E, exec, thunar
windowrule = opacity 0.75 override, no_blur on, match:class ^(kitty)$
